# Runtime selection
APP_ENV=local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
SUPABASE_PROJECT_REF=local
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# AI providers
# If AI_PROVIDER is blank, the app will automatically use Anthropic when
# ANTHROPIC_API_KEY is present. Otherwise it falls back to the mock adapter.
# AI_PROVIDER=anthropic
# AI_CHAT_MODEL=claude-haiku-4-5
# AI_FAST_MODEL=claude-haiku-4-5
# AI_GENERATION_MODEL=claude-haiku-4-5
# AI_FALLBACK_MODEL=claude-haiku-4-5
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=


# AI providers
# Set AI_PROVIDER=ollama to use a local Ollama server through its
# Anthropic-compatible API. Change the model tags below to match the models
# you have pulled locally.
AI_PROVIDER=ollama
AI_CHAT_MODEL=gemma4:e4b
AI_FAST_MODEL=gemma4:e4b
AI_GENERATION_MODEL=gemma4:e4b
AI_FALLBACK_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_AUTH_TOKEN=ollama

# Optional Ollama runtime hints.
OLLAMA_NUM_CTX=8192
OLLAMA_KEEP_ALIVE=5m


# Inngest
INNGEST_BASE_URL=http://127.0.0.1:8288
INNGEST_EVENT_KEY=dev-event-key
INNGEST_SIGNING_KEY=dev-signing-key
